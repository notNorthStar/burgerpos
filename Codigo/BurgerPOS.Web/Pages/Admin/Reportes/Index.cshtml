@page
@model BurgerPOS.Web.Pages.Admin.Reportes.IndexModel
@{
    ViewData["Title"] = "Reporte de ventas";
}

<h3 class="mb-3">Reporte de ventas</h3>

<form method="get" class="row g-2 align-items-end mb-4">
    <div class="col-auto">
        <label class="form-label">Desde</label>
        <input type="date" name="desde" value="@Model.Desde.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <label class="form-label">Hasta</label>
        <input type="date" name="hasta" value="@Model.Hasta.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
    </div>
    <div class="col-auto"><button type="submit" class="btn btn-dark btn-sm">Filtrar</button></div>
</form>

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card text-center"><div class="card-body">
            <div class="fs-4 fw-bold">@Model.TotalVentas</div><small class="text-muted">Ventas</small>
        </div></div>
    </div>
    <div class="col-md-2">
        <div class="card text-center"><div class="card-body">
            <div class="fs-5 fw-bold">$@Model.SumaSubtotales.ToString("N2")</div><small class="text-muted">Subtotal</small>
        </div></div>
    </div>
    <div class="col-md-2">
        <div class="card text-center text-success"><div class="card-body">
            <div class="fs-5 fw-bold">−$@Model.SumaDescuentos.ToString("N2")</div><small class="text-muted">Descuentos</small>
        </div></div>
    </div>
    <div class="col-md-2">
        <div class="card text-center"><div class="card-body">
            <div class="fs-5 fw-bold">$@Model.SumaIva.ToString("N2")</div><small class="text-muted">IVA</small>
        </div></div>
    </div>
    <div class="col-md-2">
        <div class="card text-center"><div class="card-body">
            <div class="fs-5 fw-bold">$@Model.SumaPropinas.ToString("N2")</div><small class="text-muted">Propinas</small>
        </div></div>
    </div>
    <div class="col-md-2">
        <div class="card text-center bg-dark text-white"><div class="card-body">
            <div class="fs-5 fw-bold">$@Model.SumaTotal.ToString("N2")</div><small>Total cobrado</small>
        </div></div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card"><div class="card-body">
            <h6>Por método de pago</h6>
            <p>Efectivo: <strong>@Model.VentasEfectivo</strong> ventas</p>
            <p>Tarjeta: <strong>@Model.VentasTarjeta</strong> ventas</p>
        </div></div>
    </div>
    @if (Model.TopProductos.Any())
    {
        <div class="col-md-4">
            <div class="card"><div class="card-body">
                <h6>Top productos</h6>
                <ol>
                    @foreach (var (nombre, qty) in Model.TopProductos)
                    {
                        <li>@nombre — <strong>@qty</strong></li>
                    }
                </ol>
            </div></div>
        </div>
    }
</div>
