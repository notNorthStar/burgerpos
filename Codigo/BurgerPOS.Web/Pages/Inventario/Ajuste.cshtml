@page
@model BurgerPOS.Web.Pages.Inventario.AjusteModel
@{
    ViewData["Title"] = "Ajuste de saldo";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Ajuste de saldo</h4>
    <a href="/Inventario" class="btn btn-outline-secondary btn-sm">Volver</a>
</div>

<div class="card" style="max-width:450px">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="mb-3">
                <label class="form-label">Insumo</label>
                <select asp-for="InsumoId" class="form-select">
                    <option value="">-- Seleccionar --</option>
                    @foreach (var i in Model.Insumos)
                    {
                        <option value="@i.Id">@i.Nombre (actual: @i.SaldoActual.ToString("N2") @i.Unidad)</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="NuevaCantidad" class="form-label">Nueva cantidad (resultado del conteo)</label>
                <input asp-for="NuevaCantidad" type="number" step="0.001" class="form-control" />
                <span asp-validation-for="NuevaCantidad" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Motivo" class="form-label">Motivo del ajuste</label>
                <textarea asp-for="Motivo" rows="2" class="form-control" placeholder="Ej: Conteo físico del 24/06/2026..."></textarea>
                <span asp-validation-for="Motivo" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-dark"
                    onclick="return confirm('¿Confirmar ajuste de saldo? Esta operación queda registrada en bitácora.')">
                Aplicar ajuste
            </button>
        </form>
    </div>
</div>
