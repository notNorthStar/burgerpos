@page
@model BurgerPOS.Web.Pages.Inventario.CrearModel
@{
    ViewData["Title"] = "Nuevo insumo";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h4>Nuevo insumo</h4>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label">Nombre</label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Unidad" class="form-label">Unidad de medida</label>
                <select asp-for="Unidad" asp-items="Model.UnidadesSelect" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="SaldoInicial" class="form-label">Saldo inicial</label>
                <input asp-for="SaldoInicial" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="SaldoInicial" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="NivelAlerta" class="form-label">Nivel de alerta</label>
                <input asp-for="NivelAlerta" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="NivelAlerta" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Guardar</button>
                <a href="/Inventario" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
