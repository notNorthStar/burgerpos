@page
@model BurgerPOS.Web.Pages.Menu.IndexModel
@{
    ViewData["Title"] = "Menu";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Menu</h3>
    <a href="/Menu/Crear" class="btn btn-dark">+ Nuevo producto</a>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <select name="categoriaId" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="">Todas las categorias</option>
            @foreach (var c in Model.Categorias)
            {
                <option value="@c.Value" selected="@(c.Value == Model.CategoriaId?.ToString())">@c.Text</option>
            }
        </select>
    </div>
    @if (Model.CategoriaId.HasValue)
    {
        <div class="col-auto">
            <a href="/Menu" class="btn btn-outline-secondary btn-sm">Limpiar filtro</a>
        </div>
    }
</form>

@if (!Model.Productos.Any())
{
    <p class="text-muted">No hay productos en esta categoría.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Descripcion</th>
                <th>Categoria</th>
                <th>Precio</th>
                <th>Disponible</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Productos)
            {
                <tr>
                    <td>@p.Nombre</td>
                    <td>@p.Descripcion</td>
                    <td>@(p.Categoria?.Nombre ?? "—")</td>
                    <td>$@p.PrecioBase.ToString("N2")</td>
                    <td>
                        @if (p.Disponible)
                        {
                            <span class="badge bg-success">Si</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td>
                        <a href="/Menu/Editar/@p.Id" class="btn btn-sm btn-outline-dark">Editar</a>
                        <a href="/Menu/Receta/@p.Id" class="btn btn-sm btn-outline-secondary ms-1">Receta</a>
                        <a href="/Menu/Modificadores/@p.Id" class="btn btn-sm btn-outline-secondary ms-1">Modificadores</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
