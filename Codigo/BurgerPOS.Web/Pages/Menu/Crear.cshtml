@page
@model BurgerPOS.Web.Pages.Menu.CrearModel
@{
    ViewData["Title"] = "Nuevo producto";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h4>Nuevo producto</h4>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label">Nombre</label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label">Descripcion</label>
                <input asp-for="Descripcion" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="PrecioBase" class="form-label">Precio base</label>
                <input asp-for="PrecioBase" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="PrecioBase" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CategoriaId" class="form-label">Categoria</label>
                <select asp-for="CategoriaId" asp-items="Model.CategoriasSelect" class="form-select">
                    <option value="">-- Selecciona --</option>
                </select>
                <span asp-validation-for="CategoriaId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Guardar</button>
                <a href="/Menu" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
