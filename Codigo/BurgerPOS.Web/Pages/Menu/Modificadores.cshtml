@page "{id:guid}"
@model BurgerPOS.Web.Pages.Menu.ModificadoresModel
@{
    ViewData["Title"] = "Modificadores";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Modificadores — @Model.Producto?.Nombre</h4>
    <a href="/Menu" class="btn btn-outline-secondary btn-sm">Volver</a>
</div>

@if (Model.Lista.Any())
{
    <table class="table table-sm table-striped mb-4" style="max-width:500px">
        <thead class="table-dark">
            <tr><th>Nombre</th><th>Delta precio</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var m in Model.Lista)
            {
                <tr>
                    <td>@m.Nombre</td>
                    <td class="@(m.DeltaPrecio >= 0 ? "text-success" : "text-danger")">
                        @(m.DeltaPrecio >= 0 ? "+" : "")$@m.DeltaPrecio.ToString("N2")
                    </td>
                    <td>
                        <form method="post" asp-page-handler="Eliminar" asp-route-id="@Model.Producto!.Id">
                            <input type="hidden" name="modificadorId" value="@m.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Quitar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted mb-4">Sin modificadores.</p>
}

<div class="card" style="max-width:400px">
    <div class="card-body">
        <h6 class="card-title">Agregar modificador</h6>
        <form method="post" asp-page-handler="Agregar" asp-route-id="@Model.Producto!.Id">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="mb-2">
                <input asp-for="Nombre" class="form-control form-control-sm" placeholder="Nombre (ej: Extra queso)" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="mb-2">
                <input asp-for="DeltaPrecio" type="number" step="0.01" class="form-control form-control-sm"
                       placeholder="Delta precio (+15 o -5)" />
            </div>
            <button type="submit" class="btn btn-dark btn-sm">Agregar</button>
        </form>
    </div>
</div>
