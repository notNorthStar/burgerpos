@page
@model BurgerPOS.Web.Pages.Ventas.TicketModel
@{
    ViewData["Title"] = "Ticket";
}

@if (Model.Venta is null)
{
    <p class="text-danger">Ticket no encontrado.</p>
    <a href="/Ordenes" class="btn btn-outline-secondary btn-sm">Volver</a>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Ticket #@Model.Venta.Folio</h4>
        <a href="/Ordenes" class="btn btn-outline-secondary btn-sm">Nueva orden</a>
    </div>

    <div class="card" style="max-width:500px" id="ticket">
        <div class="card-body">
            @if (Model.Establecimiento is not null)
            {
                <div class="text-center mb-3">
                    <h5 class="mb-0">@Model.Establecimiento.NombreComercial</h5>
                    <small class="text-muted">@Model.Establecimiento.Direccion</small><br />
                    <small class="text-muted">Tel. @Model.Establecimiento.Telefono</small>
                    @if (!string.IsNullOrEmpty(Model.Establecimiento.Rfc))
                    {
                        <br /><small class="text-muted">RFC: @Model.Establecimiento.Rfc</small>
                    }
                </div>
                <hr />
            }

            <div class="row mb-2">
                <div class="col">Folio</div><div class="col text-end fw-bold">#@Model.Venta.Folio</div>
            </div>
            <div class="row mb-2">
                <div class="col">Fecha</div><div class="col text-end">@Model.Venta.FechaCobro.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            @if (Model.Orden is not null)
            {
                <div class="row mb-2">
                    <div class="col">Modalidad</div>
                    <div class="col text-end">@Model.Orden.Modalidad @(Model.Orden.Mesa is not null ? $"· Mesa {Model.Orden.Mesa.Numero}" : "")</div>
                </div>
            }

            <hr />

            <table class="table table-sm mb-0">
                <thead><tr><th>Producto</th><th class="text-center">Cant.</th><th class="text-end">Precio</th><th class="text-end">Importe</th></tr></thead>
                <tbody>
                    @foreach (var l in Model.Lineas)
                    {
                        <tr>
                            <td>
                                @l.Nombre
                                @if (!string.IsNullOrEmpty(l.Nota))
                                {
                                    <br /><small class="text-muted fst-italic">@l.Nota</small>
                                }
                            </td>
                            <td class="text-center">@l.Cantidad</td>
                            <td class="text-end">$@l.PrecioUnitario.ToString("N2")</td>
                            <td class="text-end">$@((l.Cantidad * l.PrecioUnitario).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>

            <hr />

            <div class="row mb-1"><div class="col">Subtotal</div><div class="col text-end">$@Model.Venta.Subtotal.ToString("N2")</div></div>
            @if (Model.Venta.MontoDescuento > 0)
            {
                <div class="row mb-1 text-success">
                    <div class="col">Descuento@(Model.NombreCampania is not null ? $" ({Model.NombreCampania})" : "")</div>
                    <div class="col text-end">− $@Model.Venta.MontoDescuento.ToString("N2")</div>
                </div>
                <div class="row mb-1"><div class="col">Base gravable</div><div class="col text-end">$@Model.Venta.BaseGravable.ToString("N2")</div></div>
            }
            <div class="row mb-1"><div class="col">IVA (16%)</div><div class="col text-end">$@Model.Venta.Iva.ToString("N2")</div></div>
            @if (Model.Venta.Propina > 0)
            {
                <div class="row mb-1"><div class="col">Propina</div><div class="col text-end">$@Model.Venta.Propina.ToString("N2")</div></div>
            }
            <div class="row fw-bold fs-5 border-top pt-2 mt-1">
                <div class="col">TOTAL</div><div class="col text-end">$@Model.Venta.Total.ToString("N2")</div>
            </div>

            @if (Model.Pago is not null)
            {
                <hr />
                <div class="row mb-1"><div class="col">Método de pago</div><div class="col text-end">@Model.Pago.Metodo</div></div>
                @if (Model.Pago.MontoRecibido.HasValue)
                {
                    <div class="row mb-1"><div class="col">Recibido</div><div class="col text-end">$@Model.Pago.MontoRecibido.Value.ToString("N2")</div></div>
                    <div class="row fw-bold text-success"><div class="col">Cambio</div><div class="col text-end">$@(Model.Pago.Cambio?.ToString("N2") ?? "0.00")</div></div>
                }
            }

            @if (Model.Establecimiento?.LeyendaTicket is not null)
            {
                <hr /><p class="text-center text-muted small mb-0">@Model.Establecimiento.LeyendaTicket</p>
            }
        </div>
    </div>

    <div class="mt-3">
        <button onclick="window.print()" class="btn btn-outline-dark btn-sm">Imprimir / Exportar</button>
    </div>
}
