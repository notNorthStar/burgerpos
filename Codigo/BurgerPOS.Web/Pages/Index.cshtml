@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="row g-4">
    <div class="col-12">
        <h2>Bienvenido, @User.Identity?.Name</h2>
        <p class="text-muted">Sistema POS — BurgerPOS</p>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-primary h-100">
            <div class="card-body">
                <h5 class="card-title">Menu</h5>
                <p class="card-text">Gestiona productos, categorias y precios.</p>
                <a href="/Menu" class="btn btn-light btn-sm">Ir al menu</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success h-100">
            <div class="card-body">
                <h5 class="card-title">Inventario</h5>
                <p class="card-text">Consulta stock de insumos y registra entradas.</p>
                <a href="/Inventario" class="btn btn-light btn-sm">Ir al inventario</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning h-100">
            <div class="card-body">
                <h5 class="card-title">Ordenes</h5>
                <p class="card-text">Crea ordenes, agrega productos y cobra.</p>
                <a href="/Ordenes" class="btn btn-light btn-sm">Ir a ordenes</a>
            </div>
        </div>
    </div>
</div>
