@startuml P-09-actividad-corte-caja
' BurgerPOS - P-09 Realizar corte de caja (Actividad UML)
' RF-09, CU-14 + CU-15

title P-09 - Realizar corte de caja (Actividad UML)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Cliente cobro|
start
:GET /TurnoCaja/Cerrar;

|#E8F4FD|Capa Web (Razor Pages)|
:TurnoCajaPage\n.OnGetCerrarAsync();

|#FFFEF0|Capa de Persistencia|
:TurnoCajaRepository\n.ObtenerTurnoAbierto(\noperadorId);
:SELECT TurnoCaja\nWHERE Estado='Abierto';

|Capa Web (Razor Pages)|
if (Existe turno?) then (no)
  :Mensaje\n"no hay turno";
  stop
else (si)
endif

|#FFFEE0|Capa de Aplicacion|
:TurnoCajaService\n.PrepararArqueo(turnoId);

fork
  |Capa de Persistencia|
  :VentaRepository\n.SumarVentasEnEfectivo(\nturnoId);
  :SELECT SUM(total)\nWHERE MetodoPago='Efectivo';
fork again
  :TurnoCajaRepository\n.ObtenerRetiros(turnoId);
  :SELECT SUM(monto)\nFROM RetirosCaja;
end fork

|Capa de Aplicacion|
:CalcularEfectivoEsperado\n= fondoInicial\n+ totalVentasEfectivo\n- totalRetiros;

|Capa Web (Razor Pages)|
:Renderizar resumen\nde arqueo;

|Cliente cobro|
:Contar fisicamente\nel efectivo;
:Capturar monto contado;
:Capturar observaciones\n(opcional);
:Click "Arquear";

|Capa Web (Razor Pages)|
:Page.OnPostArquear(dto);

|Capa de Aplicacion|
:CalcularDiferencia\n= contado - esperado;

if (|diferencia| >\numbral configurable?) then (si)
  |Capa Web (Razor Pages)|
  :Solicitar motivo;
  |Cliente cobro|
  :Capturar motivo;
  |Capa Web (Razor Pages)|
  :OnPostArquearConMotivo();
else (no)
endif

|Cliente cobro|
:Confirmar cierre;

|Capa de Persistencia|
:BEGIN TRANSACTION;

fork
  :TurnoCajaRepository\n.CerrarTurno();
  :UPDATE TurnoCaja\nSET Estado='Cerrado',\nFechaCierre=NOW(),\nEsperado, Contado,\nDiferencia, Motivo;
fork again
  :BitacoraService\n.Registrar(\nCierreTurno);
  :INSERT BitacoraEvento;
end fork

:COMMIT;

|Capa Web (Razor Pages)|
:Renderizar reporte\nde cierre con\nopcion exportar;

|Cliente cobro|
:Ver reporte\ny exportar si quiere;
stop

@enduml
