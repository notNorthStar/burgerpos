@startuml P-05-actividad-preparar-orden-lista
' BurgerPOS - P-05 Preparar y marcar orden lista (Actividad UML)
' RF-04, CU-05 + CU-06

title P-05 - Preparar y marcar orden lista (Actividad UML)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}

|#FAFAFA|Cliente cocinero|
start
:GET /Cocina;

|#E8F4FD|Capa Web (Razor Pages)|
:CocinaPage.OnGetAsync();

|#FFFEF0|Capa de Persistencia|
:OrdenRepository\n.ListarPorEstado(\nEnviadaACocina,\nEnPreparacion);
:SELECT FROM Ordenes\nORDER BY FechaEnvio ASC;

|Capa Web (Razor Pages)|
:Renderizar cola FIFO\ncon SignalR client\nsuscrito a CocinaHub;

|Cliente cocinero|
:Ver cola con detalle\nde lineas y notas;
:Preparar productos;
:Click "Marcar lista"\nen orden N;

|Capa Web (Razor Pages)|
:Page.OnPostMarcarLista();

|#FFFEE0|Capa de Aplicacion|
:OrdenService\n.MarcarLista(ordenId);

fork
  |Capa de Persistencia|
  :OrdenRepository\n.ActualizarEstado(Lista);
  :UPDATE Ordenes\nSET Estado='Lista',\nFechaLista=NOW();
fork again
  |Capa de Aplicacion|
  :MeserosHubService\n.NotificarOrdenLista();

  |#FFFFE0|Cliente mesero (otra pestania)|
  :Recibir evento\n"orden-lista";
  :Agregar a vista\nde ordenes listas;
fork again
  |Capa de Aplicacion|
  :BitacoraService\n.Registrar(\nOrdenLista);
end fork

|Capa Web (Razor Pages)|
:Confirmar al cocinero;

|Cliente cocinero|
:Orden removida\nde su vista;

|Cliente mesero (otra pestania)|
:Ver orden lista;
:Recoger fisicamente\nde cocina;
:Entregar al cliente;
:Click "Marcar entregada";

|Capa Web (Razor Pages)|
:Page.OnPostMarcarEntregada();

|Capa de Aplicacion|
:OrdenService\n.MarcarEntregada(ordenId);

fork
  |Capa de Persistencia|
  :OrdenRepository\n.ActualizarEstado(Entregada);
  :UPDATE Ordenes;
fork again
  :BitacoraService\n.Registrar(\nOrdenEntregada);
end fork

|Capa Web (Razor Pages)|
:Mover a vista\n"por cobrar";

|Cliente mesero (otra pestania)|
:Confirmacion;
stop

@enduml
