@startuml P-03-actividad-tomar-orden
' BurgerPOS - P-03 Tomar orden (Actividad UML)
' RF-03, CU-04

title P-03 - Tomar orden (Actividad UML)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}

|#FAFAFA|Cliente (Navegador)|
start
:GET /TomarOrden;

|#E8F4FD|Capa Web (Razor Pages)|
:TomarOrdenPage.OnGetAsync();

|#FFFEF0|Capa de Persistencia|
:ProductoRepository\n.ListarDisponibles();
:SELECT FROM Productos\nWHERE Disponible = true;

|Capa Web (Razor Pages)|
:Renderizar menu;

|Cliente (Navegador)|
:Seleccionar modalidad\n(Mesa/Mostrador/\nPara llevar);

if (Modalidad = Mesa?) then (si)
  :Capturar numero\nde mesa;
else (no)
endif

|Capa Web (Razor Pages)|
:Page.OnPostCrearOrdenAsync();

|#FFFEE0|Capa de Aplicacion|
:OrdenService\n.CrearOrden(\noperador, modalidad);

|Capa de Persistencia|
:OrdenRepository\n.CrearBorrador();
:INSERT INTO Ordenes\n(Estado='Borrador');

|Capa Web (Razor Pages)|
:Devolver ordenId\na cliente;

|Cliente (Navegador)|
repeat
  :Seleccionar producto\no combo;
  :Definir cantidad;
  :Marcar modificadores\n(extra queso, etc.);
  :Capturar nota libre\n(opcional);

  |Capa Web (Razor Pages)|
  :Page.OnPostAgregarLinea();

  |Capa de Aplicacion|
  :OrdenService\n.AgregarLinea(\nordenId, dto);

  |Capa de Persistencia|
  :ProductoRepository\n.ObtenerPrecioActual();
  :OrdenRepository\n.InsertarLinea();
  :INSERT LineasOrden\n+ Modificadores;

  |Capa de Aplicacion|
  :RecalcularSubtotal();

  |Capa Web (Razor Pages)|
  :Devolver subtotal\nactualizado (Ajax);

  |Cliente (Navegador)|
  :Ver subtotal\nactualizado;
repeat while (Agregar mas\nproductos?) is (si) not (no)

:Revisar resumen;
:Click "Enviar a cocina";

|Capa Web (Razor Pages)|
:Page.OnPostEnviarAsync();

|Capa de Aplicacion|
:OrdenService\n.EnviarACocina(ordenId);

|Capa de Persistencia|
:ProductoRepository\n.VerificarDisponibilidad();

|Capa de Aplicacion|
if (Todos los productos\nsiguen disponibles?) then (no)
  |Capa Web (Razor Pages)|
  :Notificar productos\nno disponibles;

  |Cliente (Navegador)|
  :Retirar de la orden;
  stop
else (si)
endif

fork
  |Capa de Persistencia|
  :OrdenRepository\n.ActualizarEstado(\nEnviadaACocina);
  :UPDATE Ordenes;
fork again
  |Capa de Aplicacion|
  :CocinaHubService\n.BroadcastNuevaOrden();
  note right
    SignalR push
    a CocinaPage
  end note
fork again
  :BitacoraService\n.Registrar(\nOrdenEnviada);
end fork

|Capa Web (Razor Pages)|
:Confirmacion al cliente;

|Cliente (Navegador)|
:Ver "Orden enviada\na cocina";
stop

@enduml
