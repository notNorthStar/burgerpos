@startuml P-06-actividad-procesar-cobro
' BurgerPOS - P-06 Procesar cobro (Actividad UML)
' RF-05, CU-07 + CU-21

title P-06 - Procesar cobro (Actividad UML)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Cliente cobro|
start
:Seleccionar orden\nde lista por cobrar;

|#E8F4FD|Capa Web (Razor Pages)|
:CobroPage.OnGetAsync(ordenId);

|#FFFEF0|Capa de Persistencia|
:OrdenRepository\n.BuscarConLineas();
:TurnoCajaRepository\n.ObtenerTurnoAbierto();

|Capa Web (Razor Pages)|
if (Hay turno abierto?) then (no)
  :Redirigir a abrir turno;
  stop
else (si)
endif

:Renderizar pagina\nde cobro;

|Cliente cobro|
if (Aplicar descuento?) then (si)
  :Click "Aplicar descuento";

  |Capa Web (Razor Pages)|
  :Page.OnGetCampaniasVigentes();

  |Capa de Persistencia|
  :CampaniaRepository\n.ListarVigentes(ahora);

  |Cliente cobro|
  :Seleccionar campania;

  |#FFFEE0|Capa de Aplicacion|
  :CobroService\n.CalcularDescuento();
else (no)
endif

|Cliente cobro|
:Capturar propina\n(opcional);
:Seleccionar metodo\nde pago;

if (Metodo?) then (Efectivo)
  :Capturar monto\nrecibido;
else (Tarjeta)
endif

:Click "Confirmar cobro";

|Capa Web (Razor Pages)|
:Page.OnPostProcesarAsync(dto);

|Capa de Aplicacion|
:CobroService\n.ProcesarCobro(dto);

:CalcularTotal()\nRN-06:\nsubtotal - descuento\n= base gravable\n+ IVA 16%\n+ propina\n= total;

if (Metodo efectivo y\nmonto < total?) then (si)
  |Capa Web (Razor Pages)|
  :Devolver ErrorMontoInsuficiente;
  |Cliente cobro|
  :Corregir;
  stop
else (no)
endif

|Capa de Persistencia|
:VentaRepository\n.AsignarFolioYGuardar();
:BEGIN TRANSACTION;
:SELECT MAX(folio)+1\nFOR UPDATE;
:INSERT Venta + Pago\n+ DescuentoAplicado;
:COMMIT;
note right: RN-02 folio\nconsecutivo

|Capa de Aplicacion|
fork
  :InventarioService\n.DescontarPorVenta();
  |Capa de Persistencia|
  :UPDATE Insumos\nSET Saldo -= consumo;
fork again
  |Capa de Aplicacion|
  :TicketService\n.GenerarTicketDigital()\n(invoca P-07);
  |Capa de Persistencia|
  :INSERT Ticket;
fork again
  |Capa de Persistencia|
  :OrdenRepository\n.ActualizarEstado(Cobrada);
fork again
  |Capa de Aplicacion|
  :BitacoraService\n.Registrar(Venta);
end fork

|Capa Web (Razor Pages)|
:Redirigir a /Ticket/{id};

|Cliente cobro|
:Ver ticket digital;
:Entregar cambio\nsi aplica;
stop

@enduml
