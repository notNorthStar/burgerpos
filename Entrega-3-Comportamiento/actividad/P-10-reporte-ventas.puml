@startuml P-10-actividad-reporte-ventas
' BurgerPOS - P-10 Generar reporte de ventas (Actividad UML)
' RF-08, CU-13

title P-10 - Generar reporte de ventas (Actividad UML)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Cliente admin|
start
:GET /Reportes/Ventas;

|#E8F4FD|Capa Web (Razor Pages)|
:ReportesPage.OnGetAsync();
:Renderizar formulario\ncon filtros y presets;

|Cliente admin|
:Seleccionar rango;

if (Tipo de rango?) then (Preset)
  :Elegir diario / semanal /\nmensual;
else (Personalizado)
  :Capturar fechaInicio\ny fechaFin;
endif

:(Opcional) aplicar filtros:\nmodalidad, operador,\ncategoria;
:Click "Generar";

|Capa Web (Razor Pages)|
:Page.OnPostGenerarAsync(filtros);

|#FFFEE0|Capa de Aplicacion|
:ReporteService\n.GenerarReporte(filtros);
:ValidarRango(inicio <= fin);

if (Rango valido?) then (no)
  |Capa Web (Razor Pages)|
  :Devolver ErrorRango;
  |Cliente admin|
  :Corregir;
  stop
else (si)
endif

|#FFFEF0|Capa de Persistencia|
:VentaRepository\n.ConsultarNoAnuladas\n(inicio, fin, filtros);
:SELECT V.*, L.*, P.*\nFROM Ventas V\nJOIN Lineas L\nJOIN Pagos P\nWHERE FechaCobro BETWEEN\nAND Anulada = false;
note right
  Excluye anuladas
  para no contaminar
  metricas (RF-10).
end note

|Capa de Aplicacion|
if (Hay datos?) then (no)
  |Capa Web (Razor Pages)|
  :Mensaje "sin datos";
  stop
else (si)
endif

fork
  :CalcularIndicadores:\n- Total bruto\n- Num. transacciones\n- Productos top\n- Promedio por venta\n- Total propinas\n- Total descontado\n- IVA recaudado\n- Comisiones bancarias\n- Ganancia bruta\n- Ganancia neta;
fork again
  :DesglosarPorMetodoPago\n(efectivo vs tarjeta);
fork again
  :BitacoraService\n.Registrar(\nConsultaReporte);
end fork

|Capa Web (Razor Pages)|
:Renderizar tablas\ny graficos simples;

|Cliente admin|
:Visualizar reporte;

if (Exportar?) then (si)
  :Click "Exportar PDF";

  |Capa Web (Razor Pages)|
  :Page.OnGetExportarAsync();

  |Capa de Aplicacion|
  :PdfRenderer\n.Renderizar(reporte);

  |Capa Web (Razor Pages)|
  :Stream PDF;

  |Cliente admin|
  :Descargar;
else (no)
endif
stop

@enduml
