@startuml P-04-actividad-enviar-orden-cocina
' BurgerPOS - P-04 Enviar orden a cocina (Actividad UML)
' RF-03 -> RF-04, CU-04

title P-04 - Enviar orden a cocina (Actividad UML)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Cliente operador|
start
:Click "Enviar a cocina"\nen TomarOrdenPage;

|#E8F4FD|Capa Web (Razor Pages)|
:TomarOrdenPage\n.OnPostEnviarAsync(ordenId);

|#FFFEE0|Capa de Aplicacion|
:OrdenService\n.EnviarACocina(ordenId);

|#FFFEF0|Capa de Persistencia|
:OrdenRepository\n.BuscarPorId(\nincluyendo lineas);
:SELECT Orden + Lineas\n+ Modificadores;

|Capa de Aplicacion|
:ValidarTieneLineas(orden);

if (Orden tiene\nlineas?) then (no)
  |Capa Web (Razor Pages)|
  :Retornar ErrorOrdenVacia;
  |Cliente operador|
  :Mostrar error;
  stop
else (si)
endif

|Capa de Persistencia|
:ProductoRepository\n.VerificarDisponibilidad();
:SELECT Disponible\nFROM Productos\nWHERE Id IN @ids;

|Capa de Aplicacion|
if (Algun producto\nno disponible?) then (si)
  |Capa Web (Razor Pages)|
  :Devolver lista\nde no disponibles;

  |Cliente operador|
  :Ver alerta y\nretirar productos;
  stop
else (no)
endif

fork
  |Capa de Persistencia|
  :OrdenRepository\n.ActualizarEstado(\nEnviadaACocina);
  :UPDATE Ordenes\nSET Estado,\nFechaEnvio = NOW();
fork again
  |Capa de Aplicacion|
  :CocinaHubService\n.BroadcastNuevaOrden();
  note right
    WebSocket push
    a CocinaPage
  end note

  |#FFFFE0|Cliente cocinero (otra pestania)|
  :Recibir evento\n"orden-nueva";
  :Actualizar cola FIFO\nen pantalla;
fork again
  |Capa de Aplicacion|
  :BitacoraService\n.Registrar(\nOrdenEnviada);
  |Capa de Persistencia|
  :INSERT BitacoraEvento;
end fork

|Capa Web (Razor Pages)|
:Retornar confirmacion;

|Cliente operador|
:Mostrar "Orden enviada";
stop

@enduml
