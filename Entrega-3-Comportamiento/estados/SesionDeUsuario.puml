@startuml estado-sesion-de-usuario
' BurgerPOS - Maquina de estados de SesionDeUsuario
' Clase: Identidad.SesionUsuario
' Procesos: P-01    RF: RF-01, RF-12

title Maquina de estados - SesionDeUsuario

skinparam shadowing false
skinparam linetype polyline
skinparam roundCorner 0
skinparam state {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  ArrowColor #555
  StartColor #2E6FAC
  EndColor #B8860B
  FontSize 11
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

[*] --> NoIniciada : -\n(usuario sin\nautenticar)

state NoIniciada {
  NoIniciada : Estado conceptual
  NoIniciada : previo. El registro
  NoIniciada : aun no existe en BD.
}
NoIniciada --> Activa : iniciar(usuario,\nrolOperativo?)\n[credenciales validas,\nP-01]

state Activa {
  Activa : Sesion creada con
  Activa : cookie emitida y
  Activa : actividad reciente.
  Activa : Operaciones normales.
}
Activa --> Activa : registrarActividad()\n[cada interaccion\nrenueva el timer]
Activa --> Inactiva : timeoutInactividad()\n[sin actividad por\n>=30 min (configurable)]
Activa --> Cerrada : logout()\n[usuario sale\nexplicitamente]

state Inactiva {
  Inactiva : Sesion sin actividad
  Inactiva : reciente. Cookie aun
  Inactiva : valida hasta TTL.
  Inactiva : Pide reauth al volver.
}
Inactiva --> Activa : reautenticar()\n[ingreso credenciales\ndel usuario]
Inactiva --> Cerrada : timeoutAbsoluto()\n[expira TTL\ntotal de cookie]

state Cerrada {
  Cerrada : Sesion finalizada.
  Cerrada : Cookie invalidada.
  Cerrada : Registro queda en
  Cerrada : historial con duracion.
  Cerrada : Estado terminal.
}
Cerrada --> [*] : -

note right of Activa
  Cada peticion HTTP autenticada
  actualiza UltimaActividad. La
  bitacora (RF-12) asocia cada
  evento al SesionUsuarioId
  vigente, permitiendo trazar
  quien hizo que en el turno.
end note

note left of Inactiva
  La distincion entre Activa e
  Inactiva permite cerrar sesion
  automaticamente sin perder
  contexto: el usuario solo
  recaptura su contrasena para
  recuperar la sesion existente.
end note

@enduml
