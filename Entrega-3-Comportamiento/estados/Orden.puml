@startuml estado-orden
' ======================================================================
' BurgerPOS - Maquina de estados del objeto Orden
' Diagrama de Cambio de Estado UML (State Machine)
'
' Modela el ciclo de vida de una Orden desde su creacion (como Borrador
' en la pantalla de toma) hasta su cierre (Cobrada o Cancelada).
'
' Clase relacionada: Catalogo.Ordenes.Orden (diagrama de clases)
' Procesos que disparan transiciones: P-03, P-04, P-05, P-06
' RF asociados: RF-03, RF-04, RF-05, RF-10
' ======================================================================

title Maquina de estados - Orden

skinparam shadowing false
skinparam linetype polyline
skinparam roundCorner 0
skinparam state {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  ArrowColor #555
  StartColor #2E6FAC
  EndColor #B8860B
  FontSize 11
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

[*] --> Borrador : crear(operador,\nmodalidad)\n[P-03]

state Borrador {
  Borrador : Operador agrega,
  Borrador : edita o elimina
  Borrador : lineas libremente.
  Borrador : Subtotal preliminar
  Borrador : se recalcula en cada
  Borrador : cambio.
}
Borrador --> EnviadaACocina : enviarACocina()\n[lineas > 0,\nproductos disponibles]\n[P-04]
Borrador --> Cancelada : cancelar(motivo)\n[CU-16]

state EnviadaACocina {
  EnviadaACocina : En cola FIFO
  EnviadaACocina : visible en
  EnviadaACocina : pantalla de cocina.
}
EnviadaACocina --> EnPreparacion : iniciarPreparacion()\n[cocinero toma]
EnviadaACocina --> Cancelada : cancelar(motivo)\n[notifica a cocina]

state EnPreparacion {
  EnPreparacion : Cocinero esta
  EnPreparacion : preparando los
  EnPreparacion : productos segun
  EnPreparacion : modificadores y notas.
}
EnPreparacion --> Lista : marcarLista()\n[P-05]
EnPreparacion --> Cancelada : cancelar(motivo)\n[detener preparacion]

state Lista {
  Lista : Aparece en vista
  Lista : de meseros con
  Lista : indicador visual.
}
Lista --> Entregada : marcarEntregada()\n[mesero recoge\ny entrega cliente]
Lista --> Cancelada : cancelar(motivo)\n[cliente rechaza]

state Entregada {
  Entregada : Disponible para
  Entregada : cobro en lista de
  Entregada : "por cobrar".
}
Entregada --> Cobrada : procesarCobro()\n[venta confirmada\ncon folio]\n[P-06]
Entregada --> Cancelada : cancelar(motivo)\n[antes de cobrar]

state Cobrada {
  Cobrada : Folio consecutivo
  Cobrada : asignado, inventario
  Cobrada : descontado, ticket
  Cobrada : digital emitido.
  Cobrada : Estado terminal.
}
Cobrada --> [*]

state Cancelada {
  Cancelada : Invalidada con motivo
  Cancelada : en bitacora. No genera
  Cancelada : venta. Estado terminal.
}
Cancelada --> [*]

note right of Cobrada
  <b>Importante:</b> una Orden
  Cobrada es <b>inmutable</b> (RN-03).
  Si la venta se anula despues
  (CU-17), eso se modela en la
  maquina de estados del Pago,
  no aqui. La Orden permanece
  en estado Cobrada.
end note

note left of Borrador
  La Orden se crea en Borrador
  durante la pantalla de toma
  de orden (CU-04, P-03). El
  operador puede modificar
  libremente hasta enviar.
end note

@enduml
