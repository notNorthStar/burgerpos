@startuml estado-insumo-inventario
' BurgerPOS - Maquina de estados de InsumoInventario
' Clase: Inventario.Insumo
' Procesos: P-06 (consumo), P-08 (entrada)    RF: RF-07

title Maquina de estados - InsumoInventario

skinparam shadowing false
skinparam linetype polyline
skinparam roundCorner 0
skinparam state {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  ArrowColor #555
  StartColor #2E6FAC
  EndColor #B8860B
  FontSize 11
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

[*] --> Disponible : crear()\n[admin, CU-09]

state Disponible
Disponible : saldo > nivelAlerta
Disponible : Operacion normal,
Disponible : sin alertas

state NivelBajo
NivelBajo : 0 < saldo <= alerta
NivelBajo : Alerta visible al
NivelBajo : admin y operadores

state Agotado
Agotado : saldo = 0
Agotado : Productos asociados
Agotado : se marcan NoDisponible

state Reabastecido
Reabastecido : Estado transitorio
Reabastecido : tras entrada desde
Reabastecido : Agotado

Disponible --> NivelBajo : descontar / merma\n[saldo <= alerta]
NivelBajo --> Disponible : entrada\n[saldo > alerta]
NivelBajo --> Agotado : descontar / merma\n[saldo = 0]
Agotado --> Reabastecido : entrada()
Reabastecido --> Disponible : auto()\n[saldo > alerta]
Reabastecido --> NivelBajo : auto()\n[saldo <= alerta]
Agotado --> Disponible : ajustarSaldo()\n[admin captura\nsaldo > alerta]

Disponible --> [*] : desactivar()

note right of Disponible
  desactivar() es aplicable
  desde cualquier estado.
  Se ilustra desde Disponible
  por claridad.
end note

note left of NivelBajo
  El nivel de alerta es
  configurable por insumo.
  Se evalua tras cada
  movimiento.
end note

@enduml
