@startuml estado-entrada-inventario
' BurgerPOS - Maquina de estados de EntradaInventario
' Clase: Inventario.EntradaInventario
' Procesos: P-08    RF: RF-07

title Maquina de estados - EntradaInventario

skinparam shadowing false
skinparam linetype polyline
skinparam roundCorner 0
skinparam state {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  ArrowColor #555
  StartColor #2E6FAC
  EndColor #B8860B
  FontSize 11
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

[*] --> Borrador : iniciar()\n[usuario abre\nformulario, P-08]

state Borrador {
  Borrador : Usuario capturando
  Borrador : insumo, cantidad y
  Borrador : opcionalmente
  Borrador : proveedor y costo.
  Borrador : Saldo aun NO modificado.
}
Borrador --> Confirmada : confirmar()\n[POST validado,\ntransaccion exitosa]
Borrador --> [*] : descartar()\n[usuario cancela\nantes de POST]

state Confirmada {
  Confirmada : Saldo del insumo
  Confirmada : aumentado. Movimiento
  Confirmada : persistido en BD y
  Confirmada : en bitacora. La
  Confirmada : entrada es inmutable.
}
Confirmada --> Cancelada : cancelar(\nmotivo, admin)\n[solo admin, para\ncorregir error de\ncaptura grave]

state Cancelada {
  Cancelada : Entrada anulada con
  Cancelada : motivo obligatorio.
  Cancelada : Saldo revertido (se
  Cancelada : resta lo que se habia
  Cancelada : sumado). Estado terminal.
}
Cancelada --> [*] : -

note right of Confirmada
  La entrada es deliberadamente
  inmutable. Si hay un error en
  cantidad capturada, las
  alternativas son:
  1. Cancelar la entrada (requiere
     admin con motivo) y registrar
     una nueva correcta.
  2. Hacer un ajuste libre de
     saldo (CU-12, RF-07 paso 4).
  La opcion preferida es la 2
  porque es mas trazable.
end note

note left of Borrador
  La entrada en estado Borrador
  no tiene representacion en BD;
  solo existe en el formulario
  del navegador. Si el usuario
  cierra sin enviar, no queda
  rastro.
end note

@enduml
