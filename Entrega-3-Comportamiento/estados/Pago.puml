@startuml estado-pago
' BurgerPOS - Maquina de estados de Pago
' Clase: Cobro.Pago
' Procesos: P-06    RF: RF-05, RF-10

title Maquina de estados - Pago

skinparam shadowing false
skinparam linetype polyline
skinparam roundCorner 0
skinparam state {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  ArrowColor #555
  StartColor #2E6FAC
  EndColor #B8860B
  FontSize 11
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

[*] --> Pendiente : iniciarCobro(orden)\n[operador abre\npantalla de cobro, P-06]

state Pendiente {
  Pendiente : Operador esta capturando
  Pendiente : metodo de pago, propina,
  Pendiente : descuento. Aun nada se
  Pendiente : ha confirmado en BD.
}
Pendiente --> Procesando : confirmar(\nmetodo, monto)
Pendiente --> [*] : cancelar()\n[operador abandona\nantes de confirmar]

state Procesando {
  Procesando : Calculando total,
  Procesando : asignando folio,
  Procesando : insertando registros
  Procesando : en transaccion.
}
Procesando --> Aprobado : exitoso()\n[transaccion ok,\nfolio asignado]
Procesando --> Rechazado : fallar(motivo)\n[monto insuficiente\no error en BD]

state Aprobado {
  Aprobado : Venta registrada
  Aprobado : con folio. Inventario
  Aprobado : descontado, ticket
  Aprobado : emitido. Orden = Cobrada.
}
Aprobado --> Reembolsado : anularVenta(\nmotivo, admin)\n[CU-17, requiere\nautenticacion admin]

state Rechazado {
  Rechazado : Pago invalidado.
  Rechazado : Orden vuelve al
  Rechazado : estado anterior.
  Rechazado : Sin efectos en BD.
}
Rechazado --> [*] : -

state Reembolsado {
  Reembolsado : Venta marcada como
  Reembolsado : anulada. Folio se
  Reembolsado : conserva (RN-02).
  Reembolsado : Inventario revertido.
  Reembolsado : Estado terminal.
}
Reembolsado --> [*] : -

note right of Aprobado
  La transicion Aprobado ->
  Reembolsado es la unica forma
  de "modificar" una venta tras
  el cobro. RN-03 venta inmutable
  se respeta porque el folio se
  conserva y la anulacion queda
  en bitacora.
end note

note left of Procesando
  Estado transitorio durante la
  transaccion BD. Si el sistema
  cae aqui, al reiniciar se
  considera rechazado y no se
  emite la venta (RNF-05).
end note

@enduml
