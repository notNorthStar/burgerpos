@startuml estado-producto
' BurgerPOS - Maquina de estados de Producto
' Clase: Catalogo.Producto
' Procesos: P-02    RF: RF-02

title Maquina de estados - Producto

skinparam shadowing false
skinparam linetype polyline
skinparam roundCorner 0
skinparam state {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  ArrowColor #555
  StartColor #2E6FAC
  EndColor #B8860B
  FontSize 11
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

[*] --> Borrador : crear()\n[admin inicia\nformulario, P-02]

state Borrador {
  Borrador : Producto en creacion.
  Borrador : Datos incompletos,
  Borrador : no aparece en menu
  Borrador : ni en pantallas
  Borrador : operativas.
}
Borrador --> Activo : activar()\n[completar datos y\nreceta valida]
Borrador --> [*] : descartar()\n[admin cancela\ncreacion]

state Activo {
  Activo : Disponible en menu
  Activo : y para tomar ordenes.
  Activo : Aparece en todas las
  Activo : pantallas operativas.
}
Activo --> NoDisponible : marcarNoDisponible()\n[insumo agotado\no decision temporal]
Activo --> Descontinuado : descontinuar()\n[admin lo retira\npermanentemente]
Activo --> Activo : editar()\n[admin actualiza\nprecio o receta;\nventas pasadas\nconservan precio\nhistorico - RN-04]

state NoDisponible {
  NoDisponible : Visible en panel
  NoDisponible : de admin pero NO
  NoDisponible : en menu para tomar
  NoDisponible : nuevas ordenes.
}
NoDisponible --> Activo : reactivar()\n[insumo repuesto\no decision]
NoDisponible --> Descontinuado : descontinuar()

state Descontinuado {
  Descontinuado : Retirado del menu
  Descontinuado : permanentemente.
  Descontinuado : Las ventas pasadas
  Descontinuado : se conservan con
  Descontinuado : sus datos historicos.
}
Descontinuado --> Activo : reactivar()\n[reincorpora al menu]
Descontinuado --> [*] : eliminar()\n[admin lo borra\ndefinitivamente]

note right of Activo
  El cambio de precio se aplica
  inmediatamente para nuevas
  ordenes. Las ventas ya cobradas
  conservan el precio que tenian
  al momento del cobro (RN-04).
end note

note left of NoDisponible
  Estado tipico cuando se agota
  un insumo a mitad del turno.
  El admin u operador con permiso
  marca el producto desde el
  panel sin eliminarlo.
end note

@enduml
