@startuml P-01-secuencia-autenticar-usuario
' ======================================================================
' BurgerPOS - P-01 Autenticar usuario y declarar rol del dia
' Diagrama de Secuencia UML
' RF asociado: RF-01    Caso de uso: CU-01
' ======================================================================

title P-01 - Autenticar usuario y declarar rol del dia (Secuencia UML)

skinparam shadowing false
skinparam sequence {
  ArrowColor #555
  ActorBackgroundColor #E8F4FD
  ActorBorderColor #2E6FAC
  ParticipantBackgroundColor #F8F8F8
  ParticipantBorderColor #2E6FAC
  DatabaseBackgroundColor #FFFEF0
  DatabaseBorderColor #B8860B
  LifeLineBorderColor #999
}

actor Usuario
participant "PaginaLogin\n(Razor Page)" as Login
participant "AutenticacionService" as Auth
participant "UsuarioRepository" as UsrRepo
participant "SesionRepository" as SesRepo
participant "BitacoraService" as Bit
database "PostgreSQL" as DB

== Inicio ==

Usuario -> Login: navega a /login
activate Login
Login --> Usuario: muestra formulario de credenciales
deactivate Login

== Verificacion de credenciales ==

Usuario -> Login: POST credenciales\n(usuario, password)
activate Login
Login -> Auth: AutenticarAsync(usuario, password)
activate Auth

Auth -> UsrRepo: BuscarPorNombreUsuario(usuario)
activate UsrRepo
UsrRepo -> DB: SELECT * FROM Usuarios\nWHERE NombreUsuario = @usuario
DB --> UsrRepo: registro Usuario
UsrRepo --> Auth: Usuario o null
deactivate UsrRepo

Auth -> Auth: VerificarPasswordHash\n(password, usuario.PasswordHash)

alt credenciales validas y cuenta no bloqueada

    == Declaracion de rol (solo Operadores) ==

    alt rol del usuario = Operador
        Auth --> Login: RequiereDeclararRol
        deactivate Auth
        Login --> Usuario: muestra selector\nde rol del dia
        deactivate Login

        Usuario -> Login: POST rolOperativo\n(Cocinero / Mesero / Cobro)
        activate Login
        Login -> Auth: CompletarLogin\n(usuarioId, rolOperativo)
        activate Auth
    else rol = Administrador
        note over Auth: omite el paso\nde rol operativo
    end

    == Creacion de sesion ==

    Auth -> SesRepo: CrearSesion\n(usuario, rolOperativo?)
    activate SesRepo
    SesRepo -> DB: INSERT INTO SesionesUsuario
    DB --> SesRepo: id sesion creada
    SesRepo --> Auth: Sesion
    deactivate SesRepo

    Auth -> Bit: RegistrarEvento\n(Login, usuario, rolOperativo)
    activate Bit
    Bit -> DB: INSERT INTO BitacoraEventos
    DB --> Bit: ok
    Bit --> Auth: ok
    deactivate Bit

    Auth --> Login: SesionActiva
    deactivate Auth
    Login --> Usuario: redirige a /Inicio\n(panel del rol)
    deactivate Login

else credenciales invalidas

    Auth -> UsrRepo: IncrementarIntentosFallidos(usuario)
    activate UsrRepo
    UsrRepo -> DB: UPDATE Usuarios\nSET IntentosFallidos += 1
    UsrRepo --> Auth: nuevoConteo
    deactivate UsrRepo

    Auth -> Bit: RegistrarEvento\n(LoginFallido, usuario)
    activate Bit
    Bit -> DB: INSERT INTO BitacoraEventos
    Bit --> Auth: ok
    deactivate Bit

    alt intentos fallidos en ultima hora >= 5
        Auth -> UsrRepo: BloquearCuenta\n(usuario, 5 min)
        activate UsrRepo
        UsrRepo -> DB: UPDATE Usuarios\nSET BloqueadoHasta = @hora
        UsrRepo --> Auth: ok
        deactivate UsrRepo
        Auth --> Login: CuentaBloqueada
        deactivate Auth
        Login --> Usuario: mensaje de bloqueo\ny tiempo restante
        deactivate Login
    else intentos < 5
        Auth --> Login: CredencialesInvalidas
        deactivate Auth
        Login --> Usuario: mensaje generico:\n"Usuario o contrasena incorrectos"
        deactivate Login
    end

end

@enduml
