@startuml P-08-secuencia-entrada-inventario
' ======================================================================
' BurgerPOS - P-08 Registrar entrada de inventario
' Diagrama de Secuencia UML
' RF asociado: RF-07    Caso de uso: CU-10
' ======================================================================

title P-08 - Registrar entrada de inventario (Secuencia UML)

skinparam shadowing false
skinparam sequence {
  ArrowColor #555
  ActorBackgroundColor #E8F4FD
  ActorBorderColor #2E6FAC
  ParticipantBackgroundColor #F8F8F8
  ParticipantBorderColor #2E6FAC
  DatabaseBackgroundColor #FFFEF0
  DatabaseBorderColor #B8860B
  LifeLineBorderColor #999
}

actor "Operador / Admin" as User
participant "EntradaInventarioPage\n(Razor Page)" as Page
participant "InventarioService" as Svc
participant "InsumoRepository" as InsRepo
participant "EntradaRepository" as EntRepo
participant "BitacoraService" as Bit
database "PostgreSQL" as DB

== Carga del formulario ==

User -> Page: navega a\n/Inventario/Entrada
activate Page
Page -> InsRepo: ListarActivos()
activate InsRepo
InsRepo -> DB: SELECT FROM Insumos\nWHERE Activo = true
DB --> InsRepo: lista
InsRepo --> Page: List<Insumo>
deactivate InsRepo
Page --> User: muestra formulario\ncon dropdown de insumos
deactivate Page

== Captura y envio ==

User -> Page: selecciona insumo,\ncantidad, proveedor,\ncosto (opcionales)
User -> Page: POST "Confirmar"
activate Page
Page -> Svc: RegistrarEntrada(dto, userId)
activate Svc

Svc -> Svc: ValidarDatos(cantidad > 0,\ninsumoActivo)

alt datos invalidos
    Svc --> Page: ErroresValidacion
    Page --> User: muestra errores
else datos validos

    == Transaccion ==

    Svc -> InsRepo: BuscarPorId(insumoId)
    activate InsRepo
    InsRepo -> DB: SELECT Insumo\nFOR UPDATE
    DB --> InsRepo: Insumo
    InsRepo --> Svc: Insumo (saldo actual)
    deactivate InsRepo

    Svc -> Svc: CalcularNuevoSaldo\n(saldoActual + cantidad)

    Svc -> InsRepo: ActualizarSaldo(insumo, nuevoSaldo)
    activate InsRepo
    InsRepo -> DB: BEGIN TRANSACTION\nUPDATE Insumos\nSET Saldo = nuevoSaldo
    DB --> InsRepo: ok
    deactivate InsRepo

    Svc -> EntRepo: InsertarEntrada(entrada)
    activate EntRepo
    EntRepo -> DB: INSERT INTO\nEntradasInventario
    DB --> EntRepo: entradaId
    EntRepo --> Svc: Entrada
    deactivate EntRepo

    Svc -> Bit: RegistrarEvento\n(EntradaInventario, user, insumo, cantidad)
    activate Bit
    Bit -> DB: INSERT Bitacora\nCOMMIT
    DB --> Bit: ok
    Bit --> Svc: ok
    deactivate Bit

    Svc -> Svc: VerificarAlerta\n(saldo vs nivelAlerta)

    alt saldo paso de bajo a normal
        Svc -> Svc: LimpiarAlertaUI(insumo)
    end

    Svc --> Page: EntradaRegistrada\n(nuevoSaldo)
    Page --> User: confirmacion +\nmuestra nuevo saldo
end

deactivate Svc
deactivate Page

@enduml
