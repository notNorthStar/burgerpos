@startuml P-03-secuencia-tomar-orden
' ======================================================================
' BurgerPOS - P-03 Tomar orden
' Diagrama de Secuencia UML
' RF asociado: RF-03    Caso de uso: CU-04
' ======================================================================

title P-03 - Tomar orden (Secuencia UML)

skinparam shadowing false
skinparam sequence {
  ArrowColor #555
  ActorBackgroundColor #E8F4FD
  ActorBorderColor #2E6FAC
  ParticipantBackgroundColor #F8F8F8
  ParticipantBorderColor #2E6FAC
  DatabaseBackgroundColor #FFFEF0
  DatabaseBorderColor #B8860B
  LifeLineBorderColor #999
}

actor "Operador" as Op
participant "TomarOrdenPage\n(Razor Page)" as Page
participant "OrdenService" as Svc
participant "ProductoRepository" as ProdRepo
participant "OrdenRepository" as OrdRepo
participant "CocinaHubService\n(SignalR)" as Hub
participant "BitacoraService" as Bit
database "PostgreSQL" as DB

== Inicio de la orden ==

Op -> Page: navega a /TomarOrden
activate Page
Page -> ProdRepo: ListarDisponibles()
activate ProdRepo
ProdRepo -> DB: SELECT FROM Productos\nWHERE Disponible = true
DB --> ProdRepo: lista
ProdRepo --> Page: List<Producto>
deactivate ProdRepo
Page --> Op: muestra menu
deactivate Page

Op -> Page: selecciona modalidad\ny mesa si aplica
activate Page
Page -> Svc: CrearOrden(modalidad, mesa)
activate Svc
Svc -> OrdRepo: CrearBorrador(operadorId, modalidad)
activate OrdRepo
OrdRepo -> DB: INSERT INTO Ordenes\nestado=Borrador
DB --> OrdRepo: ordenId
OrdRepo --> Svc: Orden
deactivate OrdRepo
Svc --> Page: ordenId
deactivate Svc
Page --> Op: muestra carrito vacio
deactivate Page

== Agregar lineas (se repite por producto) ==

loop por cada producto solicitado
    Op -> Page: agrega producto con\ncantidad y modificadores
    activate Page
    Page -> Svc: AgregarLinea(ordenId,\nproductoId, cantidad, mods, nota)
    activate Svc

    Svc -> ProdRepo: ObtenerPrecioActual(productoId)
    ProdRepo --> Svc: precio

    Svc -> OrdRepo: InsertarLinea(linea)
    activate OrdRepo
    OrdRepo -> DB: INSERT INTO LineasOrden\nINSERT modificadores
    DB --> OrdRepo: ok
    OrdRepo --> Svc: linea
    deactivate OrdRepo

    Svc -> Svc: RecalcularSubtotal()
    Svc --> Page: subtotal actualizado
    deactivate Svc
    Page --> Op: muestra subtotal\nactualizado
    deactivate Page
end

== Envio a cocina ==

Op -> Page: presiona "Enviar a cocina"
activate Page
Page -> Svc: EnviarACocina(ordenId)
activate Svc

Svc -> ProdRepo: ValidarDisponibilidad(lineas)
activate ProdRepo
ProdRepo -> DB: SELECT disponibles
DB --> ProdRepo: lista
ProdRepo --> Svc: estado disponibles
deactivate ProdRepo

alt todos disponibles
    Svc -> OrdRepo: ActualizarEstado\n(ordenId, EnviadaACocina)
    OrdRepo -> DB: UPDATE Ordenes
    DB --> OrdRepo: ok

    Svc -> Hub: NotificarNuevaOrden(orden)
    activate Hub
    Hub --> Hub: broadcast a\npantalla de cocina
    deactivate Hub

    Svc -> Bit: RegistrarEvento\n(OrdenEnviada, operador, ordenId)
    Bit -> DB: INSERT Bitacora

    Svc --> Page: OrdenEnviada
    Page --> Op: confirmacion\n"Orden enviada a cocina"
else algun producto no disponible
    Svc --> Page: ProductosNoDisponibles(lista)
    Page --> Op: muestra alerta para\nretirar productos
end

deactivate Svc
deactivate Page

@enduml
