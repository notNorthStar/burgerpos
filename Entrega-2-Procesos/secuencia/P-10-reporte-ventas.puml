@startuml P-10-secuencia-reporte-ventas
' ======================================================================
' BurgerPOS - P-10 Generar reporte de ventas
' Diagrama de Secuencia UML
' RF asociado: RF-08    Caso de uso: CU-13
' ======================================================================

title P-10 - Generar reporte de ventas (Secuencia UML)

skinparam shadowing false
skinparam sequence {
  ArrowColor #555
  ActorBackgroundColor #E8F4FD
  ActorBorderColor #2E6FAC
  ParticipantBackgroundColor #F8F8F8
  ParticipantBorderColor #2E6FAC
  DatabaseBackgroundColor #FFFEF0
  DatabaseBorderColor #B8860B
  LifeLineBorderColor #999
}

actor "Administrador" as Admin
participant "ReportesPage\n(Razor Page)" as Page
participant "ReporteService" as Svc
participant "VentaRepository" as VtaRepo
participant "BitacoraService" as Bit
database "PostgreSQL" as DB
participant "PdfRenderer" as Pdf

== Carga del formulario ==

Admin -> Page: navega a\n/Reportes/Ventas
activate Page
Page --> Admin: muestra filtros\n(preset + personalizado)
deactivate Page

== Generar reporte ==

Admin -> Page: selecciona rango y filtros
Admin -> Page: click "Generar"
activate Page
Page -> Svc: GenerarReporte(filtros)
activate Svc

Svc -> Svc: ValidarRango\n(inicio <= fin)

alt rango invalido
    Svc --> Page: ErrorRango
    Page --> Admin: muestra error
else rango valido

    Svc -> VtaRepo: ConsultarVentasNoAnuladas\n(inicio, fin, filtros)
    activate VtaRepo
    VtaRepo -> DB: SELECT V.*, L.*, P.*\nFROM Ventas V\nJOIN Lineas L\nJOIN Pagos P\nWHERE V.FechaCobro BETWEEN @ini AND @fin\nAND V.Anulada = false
    DB --> VtaRepo: dataset
    VtaRepo --> Svc: List<Venta>
    deactivate VtaRepo

    alt sin datos
        Svc --> Page: SinDatos
        Page --> Admin: mensaje\n"Sin ventas en el rango"
    else con datos

        Svc -> Svc: CalcularIndicadores\n(total, # ventas, top productos,\npromedio, propinas, descuentos,\nIVA, comisiones, brutas, netas)

        Svc -> Svc: DesglosarPorMetodoPago

        Svc -> Bit: RegistrarEvento\n(ConsultaReporte, admin, rango)
        Bit -> DB: INSERT Bitacora

        Svc --> Page: ReporteVentas
        Page --> Admin: muestra tablas\ny graficos
    end
end

deactivate Svc
deactivate Page

== Exportar (opcional) ==

Admin -> Page: click "Exportar PDF"
activate Page
Page -> Pdf: Renderizar(reporte)
activate Pdf
Pdf --> Page: bytes PDF
deactivate Pdf
Page --> Admin: descarga PDF
deactivate Page

@enduml
