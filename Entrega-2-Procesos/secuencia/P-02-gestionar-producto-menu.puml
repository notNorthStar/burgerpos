@startuml P-02-secuencia-gestionar-producto-menu
' ======================================================================
' BurgerPOS - P-02 Gestionar producto del menu
' Diagrama de Secuencia UML
' RF asociado: RF-02    Caso de uso: CU-02 (con CU-03 incluido)
' ======================================================================

title P-02 - Gestionar producto del menu (Secuencia UML)

skinparam shadowing false
skinparam sequence {
  ArrowColor #555
  ActorBackgroundColor #E8F4FD
  ActorBorderColor #2E6FAC
  ParticipantBackgroundColor #F8F8F8
  ParticipantBorderColor #2E6FAC
  DatabaseBackgroundColor #FFFEF0
  DatabaseBorderColor #B8860B
  LifeLineBorderColor #999
}

actor Administrador as Admin
participant "MenuProductoPage\n(Razor Page)" as Page
participant "ProductoService" as Svc
participant "ProductoRepository" as ProdRepo
participant "InsumoRepository" as InsRepo
participant "BitacoraService" as Bit
database "PostgreSQL" as DB

== Carga inicial ==

Admin -> Page: navega a /Menu/Productos
activate Page
Page -> ProdRepo: ListarTodos()
activate ProdRepo
ProdRepo -> DB: SELECT * FROM Productos
DB --> ProdRepo: lista productos
ProdRepo --> Page: List<Producto>
deactivate ProdRepo
Page --> Admin: muestra listado
deactivate Page

== Edicion o creacion ==

Admin -> Page: click "Nuevo" o "Editar"
activate Page

alt es edicion
    Page -> ProdRepo: BuscarPorId(productoId)
    activate ProdRepo
    ProdRepo -> DB: SELECT FROM Productos\nINCLUDING modificadores, receta
    DB --> ProdRepo: Producto completo
    ProdRepo --> Page: Producto
    deactivate ProdRepo
end

Page --> Admin: muestra formulario
deactivate Page

Admin -> Page: captura datos\n(nombre, precio, categoria,\nmodificadores, receta)

== Validacion y persistencia ==

Admin -> Page: POST guardar
activate Page
Page -> Svc: GuardarProducto(dto)
activate Svc

Svc -> Svc: ValidarDatos(dto)

alt datos invalidos
    Svc --> Page: ErroresValidacion
    Page --> Admin: muestra errores
else datos validos

    Svc -> InsRepo: ValidarExistenciaInsumos\n(idsReceta)
    activate InsRepo
    InsRepo -> DB: SELECT FROM Insumos\nWHERE Id IN @ids
    DB --> InsRepo: lista
    InsRepo --> Svc: existen / faltan
    deactivate InsRepo

    alt faltan insumos
        Svc --> Page: ErrorInsumoNoEncontrado
        Page --> Admin: muestra error con\nnombres faltantes
    else todos existen

        Svc -> ProdRepo: GuardarConReceta(producto)
        activate ProdRepo
        ProdRepo -> DB: BEGIN TRANSACTION\nINSERT/UPDATE Producto\nINSERT/UPDATE Modificadores\nINSERT/UPDATE Receta\nCOMMIT
        DB --> ProdRepo: ok
        ProdRepo --> Svc: Producto persistido
        deactivate ProdRepo

        Svc -> Bit: RegistrarEvento\n(AltaProducto o EdicionProducto)
        activate Bit
        Bit -> DB: INSERT INTO Bitacora
        DB --> Bit: ok
        Bit --> Svc: ok
        deactivate Bit

        Svc --> Page: ProductoGuardado
        Page --> Admin: confirmacion +\nredirige a listado
    end
end

deactivate Svc
deactivate Page

@enduml
