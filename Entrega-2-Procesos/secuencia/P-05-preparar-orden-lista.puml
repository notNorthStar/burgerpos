@startuml P-05-secuencia-preparar-orden-lista
' ======================================================================
' BurgerPOS - P-05 Preparar y marcar orden lista
' Diagrama de Secuencia UML
' RF asociado: RF-04    Casos de uso: CU-05 y CU-06
' ======================================================================

title P-05 - Preparar y marcar orden lista (Secuencia UML)

skinparam shadowing false
skinparam sequence {
  ArrowColor #555
  ActorBackgroundColor #E8F4FD
  ActorBorderColor #2E6FAC
  ParticipantBackgroundColor #F8F8F8
  ParticipantBorderColor #2E6FAC
  DatabaseBackgroundColor #FFFEF0
  DatabaseBorderColor #B8860B
  LifeLineBorderColor #999
}

actor "Cocinero" as Cook
participant "CocinaPage\n(Razor Page)" as CocPage
participant "OrdenService" as Svc
participant "OrdenRepository" as OrdRepo
participant "MeserosHubService\n(SignalR)" as MesHub
participant "BitacoraService" as Bit
database "PostgreSQL" as DB
participant "MeserosPage\n(Razor Page)" as MesPage
actor "Mesero" as Wait

== Visualizacion de la cola FIFO ==

Cook -> CocPage: abre /Cocina
activate CocPage
CocPage -> OrdRepo: ListarPorEstado\n(EnviadaACocina, EnPreparacion)
activate OrdRepo
OrdRepo -> DB: SELECT FROM Ordenes\nORDER BY FechaEnvio ASC
DB --> OrdRepo: cola FIFO
OrdRepo --> CocPage: List<Orden>
deactivate OrdRepo
CocPage --> Cook: muestra cola con\ndetalles y notas
deactivate CocPage

== Marcar lista ==

Cook -> CocPage: click "Marcar lista"\nen orden N
activate CocPage
CocPage -> Svc: MarcarLista(ordenId)
activate Svc

Svc -> OrdRepo: ActualizarEstado\n(ordenId, Lista)
activate OrdRepo
OrdRepo -> DB: UPDATE Ordenes\nSET Estado = 'Lista',\nFechaLista = NOW()
DB --> OrdRepo: ok
OrdRepo --> Svc: ok
deactivate OrdRepo

Svc -> MesHub: NotificarOrdenLista(orden)
activate MesHub
MesHub -> MesPage: push "orden-lista"\n(WebSocket)
activate MesPage
MesPage -> MesPage: agrega a vista\nde ordenes listas
MesPage --> Wait: indicador visual + sonido
deactivate MesPage
MesHub --> Svc: ok
deactivate MesHub

Svc -> Bit: RegistrarEvento\n(OrdenLista, cocinero, ordenId)
Bit -> DB: INSERT Bitacora

Svc --> CocPage: ok
deactivate Svc
CocPage -> CocPage: remueve orden\nde cola activa
CocPage --> Cook: confirmacion
deactivate CocPage

== Entrega por el mesero ==

Wait -> MesPage: ve orden lista
activate MesPage
Wait -> MesPage: recoge fisicamente y\nclick "Marcar entregada"

MesPage -> Svc: MarcarEntregada(ordenId)
activate Svc

Svc -> OrdRepo: ActualizarEstado\n(ordenId, Entregada)
OrdRepo -> DB: UPDATE Ordenes\nSET Estado = 'Entregada'
DB --> OrdRepo: ok
OrdRepo --> Svc: ok

Svc -> Bit: RegistrarEvento\n(OrdenEntregada, mesero, ordenId)
Bit -> DB: INSERT Bitacora

Svc --> MesPage: ok
deactivate Svc
MesPage -> MesPage: mueve a historial\nde por cobrar
MesPage --> Wait: confirmacion
deactivate MesPage

@enduml
