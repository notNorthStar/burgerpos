@startuml P-09-comunicacion-corte-caja
' ======================================================================
' BurgerPOS - P-09 Realizar corte de caja
' Diagrama de Comunicacion UML
' RF asociado: RF-09    Casos de uso: CU-14 + CU-15
' ======================================================================

title P-09 - Realizar corte de caja (Comunicacion UML)

skinparam shadowing false
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  FontSize 11
}
skinparam ArrowColor #555
skinparam ArrowFontSize 10
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

rectangle "Encargado de cobro\n<<actor>>" as op #E8F4FD
rectangle "TurnoCajaPage\n(Razor Page)\n<<UI>>" as page
rectangle "TurnoCajaService\n<<service>>" as svc
rectangle "TurnoCajaRepository\n<<repository>>" as turnoRepo
rectangle "VentaRepository\n<<repository>>" as vtaRepo
rectangle "BitacoraService\n<<service>>" as bit
rectangle "PostgreSQL\n<<database>>" as db #FFFEF0

' Carga del turno
op --> page : 1: navega a\n/TurnoCaja/Cerrar
page --> turnoRepo : 2: ObtenerTurnoAbierto
turnoRepo --> db : 3: SELECT Turno abierto
db --> turnoRepo : 4: Turno
turnoRepo --> page : 5: Turno

' Calculo de esperado
page --> svc : 6: PrepararArqueo
svc --> vtaRepo : 7: SumarVentasEnEfectivo
vtaRepo --> db : 8: SELECT SUM(total)\nWHERE Metodo = Efectivo
db --> vtaRepo : 9: totalEfectivo
svc --> turnoRepo : 10: ObtenerRetiros
turnoRepo --> db : 11: SELECT SUM(retiros)
db --> turnoRepo : 12: totalRetiros
svc --> svc : 13: calcula\nefectivoEsperado
svc --> page : 14: ResumenArqueo
page --> op : 15: muestra resumen

' Captura del contado
op --> page : 16: captura contado\ny observaciones
op --> page : 17: presiona "Arquear"
page --> svc : 18: Arquear(turnoId,\ncontado, obs)
svc --> svc : 19: calcula diferencia\n(contado - esperado)

' Si diferencia > umbral, solicitar motivo
svc --> page : 20: RequiereMotivo\n(si |diff| > umbral)
page --> op : 21: solicita motivo
op --> page : 22: captura motivo

' Cierre
op --> page : 23: confirma cierre
svc --> turnoRepo : 24: CerrarTurno\n(esperado, contado,\ndiferencia, motivo)
turnoRepo --> db : 25: BEGIN + UPDATE\nTurnoCaja a Cerrado
db --> turnoRepo : 26: ok
svc --> bit : 27: RegistrarEvento\n(CierreTurno)
bit --> db : 28: INSERT Bitacora + COMMIT
svc --> page : 29: ReporteCierre
page --> op : 30: muestra reporte\ncon opcion exportar

note right of svc
  <b>Calculo del arqueo</b>
  ---
  efectivoEsperado = fondoInicial
                   + sumaVentasEfectivo
                   - sumaRetiros

  diferencia = contado - efectivoEsperado

  Si |diferencia| > umbral configurable
  (por ejemplo $50), se solicita motivo
  obligatorio antes de cerrar.
end note

note left of page
  <b>Apertura del turno (CU-14)</b>
  ---
  Aunque este diagrama detalla el
  cierre, el flujo de apertura es
  el reciproco: el operador captura
  el fondo inicial, se crea el turno
  en estado Abierto, y queda asociado
  para recibir ventas. Las ventas de
  P-06 referencian este turno hasta
  que se cierra aqui.
end note

@enduml
