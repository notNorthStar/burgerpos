@startuml P-08-comunicacion-entrada-inventario
' ======================================================================
' BurgerPOS - P-08 Registrar entrada de inventario
' Diagrama de Comunicacion UML
' RF asociado: RF-07    Caso de uso: CU-10
' ======================================================================

title P-08 - Registrar entrada de inventario (Comunicacion UML)

skinparam shadowing false
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  FontSize 11
}
skinparam ArrowColor #555
skinparam ArrowFontSize 10
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

rectangle "Operador / Admin\n<<actor>>" as user #E8F4FD
rectangle "EntradaInventarioPage\n(Razor Page)\n<<UI>>" as page
rectangle "InventarioService\n<<service>>" as svc
rectangle "InsumoRepository\n<<repository>>" as insRepo
rectangle "EntradaRepository\n<<repository>>" as entRepo
rectangle "BitacoraService\n<<service>>" as bit
rectangle "PostgreSQL\n<<database>>" as db #FFFEF0

' Carga
user --> page : 1: navega a\n/Inventario/Entrada
page --> insRepo : 2: ListarActivos
insRepo --> db : 3: SELECT Insumos\nactivos
db --> insRepo : 4: lista
insRepo --> page : 5: insumos
page --> user : 6: muestra formulario

' Captura y validacion
user --> page : 7: captura insumo,\ncantidad, proveedor, costo
user --> page : 8: POST Confirmar
page --> svc : 9: RegistrarEntrada(dto)
svc --> svc : 10: ValidarDatos

' Transaccion
svc --> insRepo : 11: BuscarPorId\nFOR UPDATE
insRepo --> db : 12: SELECT Insumo
db --> insRepo : 13: Insumo
svc --> svc : 14: CalcularNuevoSaldo
svc --> insRepo : 15: ActualizarSaldo
insRepo --> db : 16: BEGIN + UPDATE\nInsumos.Saldo
svc --> entRepo : 17: InsertarEntrada
entRepo --> db : 18: INSERT\nEntradaInventario
svc --> bit : 19: RegistrarEvento\n(EntradaInventario)
bit --> db : 20: INSERT Bitacora + COMMIT
svc --> svc : 21: VerificarAlerta
svc --> page : 22: EntradaRegistrada\n(nuevoSaldo)
page --> user : 23: confirmacion

note right of svc
  <b>Flujo alterno: validacion falla</b>
  ---
  En el paso 10, si:
  - cantidad <= 0
  - insumo no existe o esta inactivo
  retorna ErroresValidacion y no se
  ejecutan los pasos 11 a 23.

  <b>Comportamiento adicional (paso 21)</b>
  ---
  Si el saldo del insumo paso de
  estar por debajo del nivel de alerta
  a estar por encima, se limpia la
  alerta visual en las pantallas que
  la mostraban.
end note

@enduml
