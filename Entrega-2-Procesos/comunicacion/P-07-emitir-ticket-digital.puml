@startuml P-07-comunicacion-emitir-ticket-digital
' ======================================================================
' BurgerPOS - P-07 Generar y emitir ticket digital
' Diagrama de Comunicacion UML
' RF asociado: RF-06    Caso de uso: CU-08
' ======================================================================

title P-07 - Generar y emitir ticket digital (Comunicacion UML)

skinparam shadowing false
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  FontSize 11
}
skinparam ArrowColor #555
skinparam ArrowFontSize 10
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

rectangle "CobroService\n<<service>>" as cobro
rectangle "TicketService\n<<service>>" as svc
rectangle "VentaRepository\n<<repository>>" as vtaRepo
rectangle "EstablecimientoRepository\n<<repository>>" as estRepo
rectangle "TicketRepository\n<<repository>>" as tktRepo
rectangle "BitacoraService\n<<service>>" as bit
rectangle "PostgreSQL\n<<database>>" as db #FFFEF0
rectangle "Encargado de cobro\n<<actor>>" as op #E8F4FD
rectangle "TicketPage\n(Razor Page)\n<<UI>>" as page
rectangle "PdfRenderer\n<<library>>" as pdf

' Generacion automatica
cobro --> svc : 1: GenerarTicketDigital(venta)
svc --> vtaRepo : 2: ObtenerVentaConDetalle
vtaRepo --> db : 3: SELECT Venta + Lineas\n+ Pago + Descuento
db --> vtaRepo : 4: Venta completa
vtaRepo --> svc : 5: Venta
svc --> estRepo : 6: ObtenerDatosVigentes
estRepo --> db : 7: SELECT DatosEstablecimiento
db --> estRepo : 8: datos
estRepo --> svc : 9: DatosEstablecimiento
svc --> svc : 10: ComponerContenidoTicket\n(precios historicos)
svc --> tktRepo : 11: GuardarSnapshot
tktRepo --> db : 12: INSERT Ticket
db --> tktRepo : 13: ticketId
svc --> bit : 14: RegistrarEvento\n(TicketEmitido)
bit --> db : 15: INSERT Bitacora
svc --> cobro : 16: Ticket

' Visualizacion
op --> page : 17: navega a /Ticket/{id}
page --> tktRepo : 18: ObtenerPorId
tktRepo --> db : 19: SELECT Ticket
db --> tktRepo : 20: Ticket
tktRepo --> page : 21: Ticket
page --> op : 22: muestra en pantalla

' Exportacion opcional
op --> page : 23: click "Exportar PDF"
page --> pdf : 24: Renderizar(contenido)
pdf --> page : 25: bytes PDF
page --> op : 26: descarga PDF

note right of svc
  <b>Snapshot inmutable</b>
  ---
  El paso 11 guarda el contenido del
  ticket como JSON o HTML "congelado"
  en la tabla Ticket, incluyendo:
  - Precios historicos (RN-04)
  - Datos del establecimiento vigentes
    al momento (RN-05)
  Aunque el catalogo cambie despues,
  el ticket siempre se ve igual a como
  se emitio originalmente.
end note

@enduml
