@startuml P-02-bpmn-gestionar-producto-menu
' ======================================================================
' BurgerPOS - P-02 Gestionar producto del menu
' Diagrama BPMN2 (Activity Diagram con Swim Lanes)
' RF asociado: RF-02    Caso de uso: CU-02 (con CU-03 incluido)
' ======================================================================

title P-02 - Gestionar producto del menu (BPMN2)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Administrador|
start
:Entra al panel\nMenu > Productos;

if (Accion deseada?) then (Nuevo)
  :Selecciona "Nuevo producto";
else (Editar)
  :Selecciona producto\nexistente del listado;
endif

:Captura/edita datos:\nnombre, descripcion,\nprecio base, categoria,\ndisponibilidad;
:Agrega o ajusta\nmodificadores con\ndelta de precio;
:Define receta:\nselecciona insumos\ny cantidades;

|#E8F4FD|Sistema BurgerPOS|
:Valida campos obligatorios\ny precios no negativos;

if (Datos validos?) then (no)
  :Muestra errores\nde validacion;
  |Administrador|
  :Corrige y reintenta;
  stop
else (si)
endif

if (Insumos de la receta\nexisten en catalogo?) then (no)
  :Muestra error:\n"Insumo no encontrado";
  note right
    El admin debe ejecutar
    P-08 para dar de alta
    el insumo y volver
  end note
  stop
else (si)
endif

:Persiste producto y receta\nen base de datos;
:Registra evento en\nbitacora (RF-12);
:Notifica a pantallas\noperativas (reflejo\ninmediato del cambio);

|Administrador|
:Confirma vista\nactualizada;
stop

@enduml
