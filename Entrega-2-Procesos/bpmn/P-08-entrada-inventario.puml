@startuml P-08-bpmn-entrada-inventario
' ======================================================================
' BurgerPOS - P-08 Registrar entrada de inventario
' Diagrama BPMN2 (Activity Diagram con Swim Lanes)
' RF asociado: RF-07    Caso de uso: CU-10
' ======================================================================

title P-08 - Registrar entrada de inventario (BPMN2)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Operador / Administrador|
start
:Recibe mercancia\ndel proveedor;
:Entra a "Inventario"\n> "Registrar entrada";

|#E8F4FD|Sistema BurgerPOS|
:Lista insumos\nactivos del catalogo;

|Operador / Administrador|
:Selecciona insumo\nrecibido;
:Captura cantidad;
:(Opcional) captura\nproveedor y costo;
:Presiona "Confirmar";

|Sistema BurgerPOS|
:Valida datos\n(cantidad > 0,\ninsumo existe y activo);

if (Datos validos?) then (no)
  :Muestra error\nde validacion;
  |Operador / Administrador|
  :Corrige y reintenta;
  stop
else (si)
endif

:Inicia transaccion;
:Incrementa saldo\ndel insumo;
:Inserta registro de\nEntradaInventario;
:Registra evento en\nbitacora (RF-12);
:Confirma transaccion;

if (Saldo paso de bajo\na superior al nivel\nde alerta?) then (si)
  :Limpia alerta\nvisual del insumo;
else (no)
endif

|Operador / Administrador|
:Recibe confirmacion\ndel nuevo saldo;
stop

@enduml
