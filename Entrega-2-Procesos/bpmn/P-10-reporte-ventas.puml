@startuml P-10-bpmn-reporte-ventas
' ======================================================================
' BurgerPOS - P-10 Generar reporte de ventas
' Diagrama BPMN2 (Activity Diagram con Swim Lanes)
' RF asociado: RF-08    Caso de uso: CU-13
' ======================================================================

title P-10 - Generar reporte de ventas (BPMN2)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Administrador|
start
:Entra a "Reportes"\n> "Ventas";

|#E8F4FD|Sistema BurgerPOS|
:Muestra formulario\nde filtros;

|Administrador|
:Selecciona rango\nde fechas;

if (Rango?) then (Diario / Semanal / Mensual)
  :Sistema fija fechas\nsegun preset;
else (Personalizado)
  :Captura fechaInicio\ny fechaFin;
endif

:(Opcional) aplica filtros:\nmodalidad, operador,\ncategoria;
:Presiona "Generar";

|Sistema BurgerPOS|
:Valida rango\n(inicio <= fin,\nrango razonable);

if (Validacion ok?) then (no)
  :Muestra error;
  stop
else (si)
endif

:Consulta ventas no anuladas\ndel rango con filtros;

if (Hay ventas\nen el rango?) then (no)
  :Muestra mensaje\n"Sin datos en el rango";
  stop
else (si)
endif

:Calcula indicadores:\n- Total bruto\n- Numero de transacciones\n- Productos top (cantidad e ingreso)\n- Ingreso promedio por venta\n- Total propinas\n- Total descontado por campania\n- IVA recaudado\n- Comisiones bancarias\n- Ganancia bruta (total - comisiones)\n- Ganancia neta (bruta - IVA);
:Desglosa por\nmetodo de pago\n(efectivo vs tarjeta);
:Renderiza tablas\ny graficos simples;
:Persiste evento\nen bitacora\n(ConsultaReporte);

|Administrador|
:Visualiza reporte\nen pantalla;

if (Quiere exportar?) then (si)
  |Sistema BurgerPOS|
  :Genera archivo PDF\no CSV;
  |Administrador|
  :Descarga;
else (no)
endif

stop

@enduml
