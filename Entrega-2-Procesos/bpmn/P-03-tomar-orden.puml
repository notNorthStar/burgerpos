@startuml P-03-bpmn-tomar-orden
' ======================================================================
' BurgerPOS - P-03 Tomar orden
' Diagrama BPMN2 (Activity Diagram con Swim Lanes)
' RF asociado: RF-03    Caso de uso: CU-04
' ======================================================================

title P-03 - Tomar orden (BPMN2)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Operador (Mesero/Cobro)|
start
:Entra a\n"Tomar orden";
:Selecciona modalidad\nde servicio;

if (Modalidad?) then (Mesa)
  :Captura numero\nde mesa;
elseif (Mostrador) then (Mostrador)
  :Sin identificador\nadicional;
else (Para llevar)
  :Captura nombre\nde cliente (opcional);
endif

|#E8F4FD|Sistema BurgerPOS|
:Crea orden en\nestado Borrador;

|Operador (Mesero/Cobro)|
repeat
  :Selecciona producto\no combo del menu;
  :Define cantidad;

  if (Producto admite\nmodificadores?) then (si)
    :Selecciona modificadores\n(extra queso, sin tocino, etc.);
  else (no)
  endif

  :Agrega nota libre\nopcional para cocina;

  |Sistema BurgerPOS|
  :Crea linea de orden\ny recalcula subtotal\npreliminar;

  |Operador (Mesero/Cobro)|
repeat while (Agregar mas\nproductos?) is (si) not (no)

:Revisa resumen\ny subtotal;

if (Necesita ajustes?) then (si)
  :Edita, agrega o\nelimina lineas;
  stop
else (no, listo para enviar)
endif

:Presiona\n"Enviar a cocina";

|Sistema BurgerPOS|
:Valida productos\ndisponibles en catalogo;

if (Algun producto\nno disponible?) then (si)
  :Avisa al operador\nlistando productos\nno disponibles;
  |Operador (Mesero/Cobro)|
  :Retira esos productos\nde la orden;
  stop
else (no)
endif

:Cambia estado de\norden a EnviadaACocina;
:Notifica vista de\ncocina (FIFO);
:Registra evento\nen bitacora;

|Operador (Mesero/Cobro)|
:Recibe confirmacion;
stop

@enduml
