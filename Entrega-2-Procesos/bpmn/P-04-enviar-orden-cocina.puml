@startuml P-04-bpmn-enviar-orden-cocina
' ======================================================================
' BurgerPOS - P-04 Enviar orden a cocina
' Diagrama BPMN2 (Activity Diagram con Swim Lanes)
' RF asociado: RF-03 -> RF-04    Caso de uso: CU-04
' ======================================================================

title P-04 - Enviar orden a cocina (BPMN2)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Operador (Mesero)|
start
:Confirma envio\nde orden a cocina\n(desde P-03);

|#E8F4FD|Sistema BurgerPOS|
:Recibe solicitud\nde envio;

if (Orden tiene\nal menos una linea?) then (no)
  :Rechaza con error\n"Orden vacia";
  stop
else (si)
endif

:Valida disponibilidad\nde productos solicitados;

if (Algun producto\nesta marcado como\nno disponible?) then (si)
  :Construye lista\nde productos no\ndisponibles;
  :Notifica al operador;
  |Operador (Mesero)|
  :Decide retirar productos\no cancelar el envio;
  stop
else (no)
endif

:Cambia estado de\norden a EnviadaACocina\ncon timestamp;
:Asigna folio interno\nde orden (no es folio de venta);
:Persiste cambios;

:Encola la orden\nen la cola FIFO de cocina;
:Envia notificacion\nen tiempo real (SignalR)\na la pantalla de cocina;
:Registra evento en bitacora\n(OrdenEnviada);

|#FFFEF0|Cocina (pantalla)|
:Recibe la nueva orden\nen su lista FIFO;
:Sonido o highlight\nvisual segun config;

|Operador (Mesero)|
:Ve confirmacion\nde envio exitoso;
stop

@enduml
