@startuml P-01-bpmn-autenticar-usuario
' ======================================================================
' BurgerPOS - P-01 Autenticar usuario y declarar rol del dia
' Diagrama BPMN2 (representado como Activity Diagram con Swim Lanes)
' RF asociado: RF-01    Caso de uso: CU-01
' ======================================================================

title P-01 - Autenticar usuario y declarar rol del dia (BPMN2)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Usuario|
start
:Abre BurgerPOS\nen el navegador;
:Captura nombre de usuario\ny contrasena;

|#E8F4FD|Sistema BurgerPOS|
:Recibe credenciales\ny limpia formulario;
:Busca usuario en\nbase de datos;

if (Usuario existe y\ncredenciales validas?) then (si)
  if (Cuenta del usuario\nesta bloqueada?) then (no)

    if (Rol del usuario\nes Operador?) then (si)
      :Solicita declaracion\ndel rol del dia;

      |Usuario|
      :Selecciona rol\n(Cocinero / Mesero /\nEncargado de cobro);

      |Sistema BurgerPOS|
      :Recibe rol declarado;
    else (no, es Administrador)
      note right
        Admin omite el
        paso de seleccion
        de rol operativo
      end note
    endif

    :Crea sesion activa\nen base de datos;
    :Registra evento de login\nen bitacora (RF-12);
    :Redirige al panel\ncorrespondiente al rol;

    |Usuario|
    :Ingresa al sistema;
    stop

  else (si, esta bloqueada)
    |Sistema BurgerPOS|
    :Muestra mensaje\nde cuenta bloqueada;
    stop
  endif

else (no, credenciales invalidas)
  :Incrementa contador\nde intentos fallidos;
  :Registra intento fallido\nen bitacora;

  if (Intentos fallidos\nen ultima hora >= 5?) then (si)
    :Bloquea cuenta\npor 5 minutos;
    :Muestra mensaje\nde bloqueo;
    stop
  else (no)
    :Muestra mensaje\nde error generico;
    stop
  endif
endif

@enduml
