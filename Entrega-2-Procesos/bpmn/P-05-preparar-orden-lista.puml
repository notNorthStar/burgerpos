@startuml P-05-bpmn-preparar-orden-lista
' ======================================================================
' BurgerPOS - P-05 Preparar y marcar orden lista
' Diagrama BPMN2 (Activity Diagram con Swim Lanes)
' RF asociado: RF-04    Casos de uso: CU-05 y CU-06
' ======================================================================

title P-05 - Preparar y marcar orden lista (BPMN2)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Cocinero|
start
:Entra a pantalla\n"Cocina";

|#E8F4FD|Sistema BurgerPOS|
:Muestra cola FIFO\nde ordenes en estado\nEnviadaACocina;

|Cocinero|
:Toma la siguiente\norden en cola;

if (Insumos suficientes\npara la receta?) then (no)
  :Reporta merma o\ncomunica al mesero\n(invoca P-08 si aplica);
  stop
else (si)
endif

:Prepara los productos\nde la orden segun\nmodificadores y notas;
:Marca orden como Lista;

|Sistema BurgerPOS|
:Cambia estado a Lista\ncon timestamp;
:Quita orden de la\nvista activa de cocina;
:Notifica vista de\nmeseros (SignalR)\ncon orden lista;
:Registra evento\nen bitacora;

|#FFFEF0|Mesero (vista de ordenes listas)|
:Recibe notificacion\nvisual + sonido;
:Identifica la orden\ny su mesa o modalidad;
:Recoge fisicamente\nla orden de cocina;
:Entrega al cliente;
:Marca orden como\nEntregada;

|Sistema BurgerPOS|
:Cambia estado a\nEntregada;
:Mueve a historial\nde ordenes por cobrar;
:Registra evento\nen bitacora;

|#FAFAFA|Cocinero|
:Continua con la\nsiguiente orden\nen cola;
stop

@enduml
