@startuml P-06-bpmn-procesar-cobro
' ======================================================================
' BurgerPOS - P-06 Procesar cobro
' Diagrama BPMN2 (Activity Diagram con Swim Lanes)
' RF asociado: RF-05    Caso de uso: CU-07 (incluye CU-21)
' ======================================================================

title P-06 - Procesar cobro (BPMN2)

skinparam shadowing false
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #2E6FAC
  DiamondBackgroundColor #FFFEF0
  DiamondBorderColor #B8860B
  ArrowColor #555
}
skinparam swimlane {
  BorderColor #555
  TitleBackgroundColor #E8F4FD
  TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFEE0
skinparam noteBorderColor #B8860B

|#FAFAFA|Encargado de cobro|
start
:Selecciona orden\na cobrar de la lista\nde "por cobrar";

|#E8F4FD|Sistema BurgerPOS|
:Carga orden con\nlineas, modificadores\ny subtotal;

if (Hay turno de caja\nabierto?) then (no)
  :Solicita abrir turno\n(invoca P-09 apertura);
  stop
else (si)
endif

|Encargado de cobro|
if (Aplicar campania\nde descuento?) then (si)

  |Sistema BurgerPOS|
  :Lista campanias\nvigentes y aplicables;

  |Encargado de cobro|
  :Selecciona una\ncampania;

  |Sistema BurgerPOS|
  :Calcula monto descontado\nsegun tipo y alcance;
else (no)
endif

|Encargado de cobro|
if (Cliente da propina?) then (si)
  :Captura monto de propina;
else (no)
endif

:Selecciona metodo\nde pago;

if (Metodo?) then (Efectivo)
  :Captura monto\nrecibido;

  |Sistema BurgerPOS|
  :Calcula cambio\n(recibido - total);

  if (Monto suficiente?) then (no)
    :Muestra error\n"Monto insuficiente";
    |Encargado de cobro|
    :Corrige captura;
    stop
  else (si)
  endif

else (Tarjeta)
  |Sistema BurgerPOS|
  :Registra comision\nbancaria configurada;
endif

|Sistema BurgerPOS|
:Aplica orden de calculo\n(RN-06):\nsubtotal - descuento\n=> base gravable\n+ IVA 16%\n+ propina\n= total;

|Encargado de cobro|
:Revisa total y\nconfirma cobro;

|Sistema BurgerPOS|
:Genera folio\nconsecutivo unico\n(transaccional);
:Persiste venta + pago\n+ descuento aplicado;
:Asocia venta al\nturno de caja;
:Descuenta inventario\nsegun recetas\n(P-08 automatico);
:Genera ticket digital\n(invoca P-07);
:Registra evento\nen bitacora;
:Cambia estado de\norden a Cobrada;

|Encargado de cobro|
:Entrega cambio si aplica\ny ve ticket digital;
stop

@enduml
