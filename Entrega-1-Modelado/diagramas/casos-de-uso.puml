@startuml casos-de-uso
' ======================================================================
' BurgerPOS - Diagrama de Casos de Uso (Entrega 1)
' Generar:  java -jar plantuml.jar casos-de-uso.puml
'           o renderizar en https://www.plantuml.com/plantuml
' ======================================================================

title BurgerPOS - Diagrama de Casos de Uso

left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #FFFAF0
  BorderColor #B8860B
  FontSize 11
}
skinparam actor {
  BackgroundColor #E8F4FD
  BorderColor #2E6FAC
}
skinparam rectangle {
  BackgroundColor #FAFAFA
  BorderColor #555
}

actor "Administrador" as Admin
actor "Operador" as Op
actor "Sistema" as Sys

rectangle "Sistema BurgerPOS" {

  package "Identidad" {
    usecase "CU-01\nAutenticar y\ndeclarar rol" as CU01
  }

  package "Catalogo" {
    usecase "CU-02\nGestionar producto\ndel menu" as CU02
    usecase "CU-03\nDefinir receta\ndel producto" as CU03
    usecase "CU-18\nConfigurar combo" as CU18
    usecase "CU-20\nConfigurar campania\nde descuento" as CU20
    usecase "CU-22\nConfigurar datos\ndel establecimiento" as CU22
  }

  package "Ordenes" {
    usecase "CU-04\nTomar orden" as CU04
    usecase "CU-05\nAtender ordenes\nen cocina (FIFO)" as CU05
    usecase "CU-06\nVer ordenes listas\npara entregar" as CU06
    usecase "CU-16\nCancelar orden" as CU16
  }

  package "Cobro" {
    usecase "CU-07\nProcesar cobro" as CU07
    usecase "CU-08\nVisualizar y\nexportar ticket" as CU08
    usecase "CU-17\nAnular venta" as CU17
    usecase "CU-21\nAplicar descuento\nen cobro" as CU21
  }

  package "Turno" {
    usecase "CU-14\nAbrir turno\nde caja" as CU14
    usecase "CU-15\nCerrar turno\ny arquear" as CU15
  }

  package "Inventario" {
    usecase "CU-09\nDar de alta\ninsumo" as CU09
    usecase "CU-10\nRegistrar entrada\nde inventario" as CU10
    usecase "CU-11\nReportar merma" as CU11
    usecase "CU-12\nAjustar saldo\nde inventario" as CU12
  }

  package "Administracion" {
    usecase "CU-13\nConsultar reportes\nde ventas" as CU13
    usecase "CU-19\nConsultar bitacora\nde auditoria" as CU19
  }
}

' ============ Asociaciones Operador ============
Op --> CU01
Op --> CU04
Op --> CU05
Op --> CU06
Op --> CU07
Op --> CU08
Op --> CU10
Op --> CU11
Op --> CU14
Op --> CU15
Op --> CU16
Op --> CU21

' ============ Asociaciones Administrador ============
Admin --> CU01
Admin --> CU02
Admin --> CU03
Admin --> CU08
Admin --> CU09
Admin --> CU10
Admin --> CU11
Admin --> CU12
Admin --> CU13
Admin --> CU15
Admin --> CU17
Admin --> CU18
Admin --> CU19
Admin --> CU20
Admin --> CU22

' ============ Sistema (procesos automaticos) ============
Sys --> CU05 : notifica\nentrada\nFIFO
Sys --> CU06 : notifica\norden lista

' ============ Relaciones include/extend ============
CU07 ..> CU08 : <<include>>
CU07 ..> CU21 : <<extend>>
CU07 ..> CU10 : <<include>>\n(descuento\nautomatico)
CU02 ..> CU03 : <<include>>
CU18 ..> CU02 : <<extend>>
CU15 ..> CU13 : <<include>>
CU17 ..> CU19 : <<include>>
CU12 ..> CU19 : <<include>>

@enduml
